{
  "name": "uganda-cbc-sms",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build": "npm run build --workspaces --if-present",
    "migrate": "npm run migrate --workspace=apps/api",
    "setup:db-roles": "npm run setup:db-roles --workspace=apps/api",
    "transfer:db-ownership": "npm run transfer:db-ownership --workspace=apps/api",
    "seed": "npm run seed --workspace=apps/api",
    "setup": "npm run migrate && npm run seed",
    "seed:grading-scales": "npm run seed:grading-scales --workspace=apps/api",
    "seed:curriculum": "npm run seed:curriculum --workspace=apps/api",
    "backup:db": "npm run backup:db --workspace=apps/api",
    "restore:db": "npm run restore:db --workspace=apps/api",
    "test:security": "npm run test:security --workspace=apps/api",
    "seed:platform": "npm run seed:platform --workspace=apps/api",
    "recalculate:alevel-grades": "npm run recalculate:alevel-grades --workspace=apps/api",
    "billing:overdue": "npm run billing:overdue --workspace=apps/api"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "overrides": {
    "axios": "^1.17.0",
    "glob": "^10.4.6",
    "postcss": "^8.5.10",
    "next": {
      "postcss": "^8.5.10"
    },
    "tar": "7.5.15",
    "@mapbox/node-pre-gyp": {
      "tar": "7.5.15"
    }
  }
}
