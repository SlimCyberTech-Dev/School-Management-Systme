# API
PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/uganda_cbc_sms
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=10

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=2

# Fees — flag invoice when balance exceeds this (UGX)
FEE_ARREARS_THRESHOLD_UGX=500000

# Bootstrap admin (seed script only)
ADMIN_EMAIL=admin@school.local
ADMIN_PASSWORD=ChangeMe123!

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000/api
