# API
PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/school_manage

# JWT (RS256) — generate with: tsx apps/api/scripts/generate-jwt-keys.ts
# Or place PEM files in apps/api/.keys/ for local dev
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_EXPIRY=8h
# Legacy (removed after RS256 cutover):
# JWT_SECRET=

# Security
ALLOWED_ORIGINS=http://localhost:3000
SESSION_INACTIVITY_MINUTES=15
REDIS_URL=
MAX_LOGIN_ATTEMPTS=5
AUTO_BLOCK_THRESHOLD=500
REQUEST_LOG_SAMPLE_RATE=0.1
BCRYPT_ROUNDS=10

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=2
REPORT_CACHE_DIR=./cache/reports

# Fees — flag invoice when balance exceeds this (UGX)
FEE_ARREARS_THRESHOLD_UGX=500000

# Multi-tenant
APP_ROOT_DOMAIN=localhost
DEFAULT_TENANT_SLUG=default
DEFAULT_TENANT_NAME=Default School
# REQUIRED for isolation: use school_app, not postgres superuser (see docs/multitenant-isolation.md)
# Run: npm run setup:db-roles
# DATABASE_URL=postgresql://school_app:change_me_school_app@localhost:5432/school_manage
# PLATFORM_DATABASE_URL=postgresql://platform_app:change_me_platform_app@localhost:5432/school_manage
# DATABASE_URL_MIGRATE=postgresql://migration_admin:change_me_migration@localhost:5432/school_manage
# SCHOOL_APP_PASSWORD=change_me_school_app
# PLATFORM_APP_PASSWORD=change_me_platform_app
# MIGRATION_ADMIN_PASSWORD=change_me_migration

# Bootstrap admin (seed script only)
ADMIN_EMAIL=admin@school.local
ADMIN_PASSWORD=ChangeMe123!
SAMPLE_USERS_PASSWORD=ChangeMe123!

# Platform super admin (seed:platform)
PLATFORM_ADMIN_EMAIL=platform@school.local
PLATFORM_ADMIN_PASSWORD=ChangeMe123!
PLATFORM_ADMIN_NAME=Platform Super Admin

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_SESSION_INACTIVITY_MINUTES=15

# Platform billing (school subscription → SlimCyberTech)
# Dev: mock checkout completes without Flutterwave
BILLING_MOCK_PAYMENTS=true
WEB_APP_URL=http://localhost:3000
# Production: Flutterwave keys from dashboard
# FLUTTERWAVE_SECRET_KEY=
# FLUTTERWAVE_WEBHOOK_SECRET=
# Webhook URL: https://your-api/api/platform/billing/webhooks/flutterwave

# Tests (optional)
DATABASE_URL_TEST=postgresql://user:password@localhost:5432/school_manage_test
