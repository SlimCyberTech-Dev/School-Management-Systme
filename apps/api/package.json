{
  "name": "@uganda-cbc-sms/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "start:prod": "tsx scripts/migrate.ts && tsx src/index.ts",
    "migrate": "tsx scripts/migrate.ts",
    "setup:db-roles": "tsx scripts/setup-db-roles.ts",
    "setup:test-db": "tsx scripts/setup-test-database.ts",
    "transfer:db-ownership": "tsx scripts/transfer-db-ownership.ts",
    "backup:db": "tsx scripts/backup-database.ts",
    "restore:db": "tsx scripts/restore-database.ts",
    "seed": "tsx scripts/seed.ts",
    "seed:platform": "tsx scripts/seed-platform.ts",
    "seed:grading-scales": "tsx scripts/seed-grading-scales.ts",
    "seed:curriculum": "tsx scripts/seed-curriculum.ts",
    "seed:structure": "tsx scripts/seed-structure.ts",
    "recalculate:alevel-grades": "tsx scripts/recalculate-alevel-grades.ts",
    "recalculate:olevel-grades": "tsx scripts/recalculate-olevel-grades.ts",
    "billing:overdue": "tsx scripts/billing-overdue.ts",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:notifications": "tsx --test tests/notifications/notificationService.test.ts tests/notifications/examNotificationLinks.test.ts",
    "test:security": "NODE_OPTIONS=--experimental-vm-modules jest tests/security",
    "generate:jwt-keys": "tsx scripts/generate-jwt-keys.ts"
  },
  "dependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.12",
    "@types/pdfkit": "^0.13.4",
    "@types/pg": "^8.11.6",
    "@types/validator": "^13.15.10",
    "@uganda-cbc-sms/brand": "^1.0.0",
    "@uganda-cbc-sms/shared": "*",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "express-rate-limit": "^8.5.2",
    "express-slow-down": "^3.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "pdfkit": "^0.15.0",
    "pg": "^8.11.5",
    "rate-limit-redis": "^5.0.0",
    "resend": "^6.16.0",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5",
    "validator": "^13.15.35",
    "xss": "^1.0.15",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2"
  }
}
