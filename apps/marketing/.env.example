# Public URL of this marketing site (no trailing slash). Required for sitemap, canonical URLs, and Open Graph.
NEXT_PUBLIC_SITE_URL=https://schoolmanage.slimcybertech.com

# Base URL of the SchoolManage product app (no trailing slash).
NEXT_PUBLIC_APP_URL=http://default.localhost:3000

# SMTP email (e.g. Gmail with an app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=SchoolManage
