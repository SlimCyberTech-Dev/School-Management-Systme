# Base URL of the SchoolManage product app (no trailing slash).
# CtaButton links to ${NEXT_PUBLIC_APP_URL}/login
NEXT_PUBLIC_APP_URL=http://default.localhost:3000

# Third-party form handler POST URL (Formspree, Tally, Getform, etc.).
# Leave empty to use mailto: fallback on the contact form.
NEXT_PUBLIC_CONTACT_FORM_ENDPOINT=
